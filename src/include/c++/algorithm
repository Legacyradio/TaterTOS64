// TaterTOS64v3 — minimal <algorithm> for freestanding C++.
// Origin log: logs/fry835.txt
//
// AK has its own variants of most algorithms. This shim exists for
// fast_float (which uses std::copy, std::fill, std::min) and any
// future upstream code that pulls in the standard names.

#pragma once

#include <stddef.h>

namespace std {

template<typename T>
constexpr T const& min(T const& a, T const& b) noexcept {
    return (b < a) ? b : a;
}

template<typename T>
constexpr T const& max(T const& a, T const& b) noexcept {
    return (a < b) ? b : a;
}

template<typename T, typename Compare>
constexpr T const& min(T const& a, T const& b, Compare comp) noexcept {
    return comp(b, a) ? b : a;
}

template<typename T, typename Compare>
constexpr T const& max(T const& a, T const& b, Compare comp) noexcept {
    return comp(a, b) ? b : a;
}

// Generic copy / fill — random-access friendly, works on pointers.
template<typename InputIt, typename OutputIt>
constexpr OutputIt copy(InputIt first, InputIt last, OutputIt out) {
    while (first != last) {
        *out = *first;
        ++first; ++out;
    }
    return out;
}

template<typename InputIt, typename Size, typename OutputIt>
constexpr OutputIt copy_n(InputIt first, Size n, OutputIt out) {
    while (n-- > 0) {
        *out = *first;
        ++first; ++out;
    }
    return out;
}

template<typename ForwardIt, typename T>
constexpr void fill(ForwardIt first, ForwardIt last, T const& value) {
    while (first != last) {
        *first = value;
        ++first;
    }
}

template<typename OutputIt, typename Size, typename T>
constexpr OutputIt fill_n(OutputIt first, Size n, T const& value) {
    while (n-- > 0) {
        *first = value;
        ++first;
    }
    return first;
}

// swap is in <utility>; not redeclared here.

// copy_backward — used by fast_float's bigint shifting code.
template<typename BidirIt1, typename BidirIt2>
constexpr BidirIt2 copy_backward(BidirIt1 first, BidirIt1 last, BidirIt2 d_last) {
    while (first != last) {
        --last; --d_last;
        *d_last = *last;
    }
    return d_last;
}

// Generic find.
template<typename InputIt, typename T>
constexpr InputIt find(InputIt first, InputIt last, T const& value) {
    while (first != last) {
        if (*first == value) return first;
        ++first;
    }
    return last;
}

template<typename InputIt, typename T>
constexpr ptrdiff_t count(InputIt first, InputIt last, T const& value) {
    ptrdiff_t n = 0;
    while (first != last) { if (*first == value) ++n; ++first; }
    return n;
}

template<typename InputIt1, typename InputIt2>
constexpr bool equal(InputIt1 first1, InputIt1 last1, InputIt2 first2) {
    while (first1 != last1) {
        if (!(*first1 == *first2)) return false;
        ++first1; ++first2;
    }
    return true;
}

} // namespace std
