// TaterTOS64v3 — minimal <chrono> for freestanding C++.
// Surface: std::chrono::milliseconds.

#pragma once

#include <stdint.h>

namespace std {
namespace chrono {

template<typename Rep, typename Period = void>
struct duration {
    Rep m_count;
    constexpr Rep count() const { return m_count; }
};

using milliseconds = duration<int64_t>;
using seconds = duration<int64_t>;
using hours = duration<int64_t>;

} // namespace chrono

namespace literals {
namespace chrono_literals {

constexpr chrono::milliseconds operator""ms(unsigned long long m) {
    return { static_cast<int64_t>(m) };
}

constexpr chrono::seconds operator""s(unsigned long long s) {
    return { static_cast<int64_t>(s) };
}

constexpr chrono::hours operator""h(unsigned long long h) {
    return { static_cast<int64_t>(h) };
}

} // namespace chrono_literals
} // namespace literals

using namespace literals::chrono_literals;

} // namespace std
