#pragma once

#include <type_traits>

namespace std {
    template<typename T>
    concept same_as = is_same_v<T, T>; // Very minimal

    template<typename T, typename U>
    concept same_as_ext = is_same_v<T, U> && is_same_v<U, T>;

    template<typename T>
    concept destructible = true;

    template<typename T, typename... Args>
    concept constructible_from = true;

    template<typename T>
    concept move_constructible = true;

    template<typename T>
    concept copy_constructible = true;
}
