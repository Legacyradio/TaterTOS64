// TaterTOS64v3 — minimal <cstddef> for freestanding C++.
// Origin log: logs/fry831.txt
// Wraps <stddef.h> and re-exports C names into namespace std.

#pragma once

#include <stddef.h>

namespace std {

using ::size_t;
using ::ptrdiff_t;
using ::nullptr_t;

// std::max_align_t — used by AK/kmalloc.cpp:92.
// Defined to be the type whose alignment is the strictest of any
// scalar type. On x86_64 freestanding, long double has 16-byte
// alignment so we use it as the underlying type.
typedef long double max_align_t;

// std::byte — opaque byte type used in some AK low-level paths.
enum class byte : unsigned char {};

} // namespace std
