// TaterTOS64v3 — minimal <limits> for freestanding C++.
// Origin log: logs/fry834.txt
//
// std::numeric_limits<T> — mostly used by fast_float (digits, digits10,
// max/min/epsilon, is_signed, is_iec559, etc.) and occasionally by
// AK template metaprogramming. We provide an explicit specialization
// for every fundamental integer type plus float/double/long double.

#pragma once

#include <stdint.h>
#include <float.h>
#include <climits>

namespace std {

enum float_round_style {
    round_indeterminate       = -1,
    round_toward_zero         = 0,
    round_to_nearest          = 1,
    round_toward_infinity     = 2,
    round_toward_neg_infinity = 3,
};

enum float_denorm_style {
    denorm_indeterminate = -1,
    denorm_absent        = 0,
    denorm_present       = 1,
};

// Primary template — all members false / 0 by default. Specializations
// provide real values for fundamental types.
template<typename T>
struct numeric_limits {
    static constexpr bool is_specialized = false;
    static constexpr bool is_signed      = false;
    static constexpr bool is_integer     = false;
    static constexpr bool is_exact       = false;
    static constexpr bool is_iec559      = false;
    static constexpr bool is_bounded     = false;
    static constexpr bool is_modulo      = false;
    static constexpr int  digits         = 0;
    static constexpr int  digits10       = 0;
    static constexpr int  max_digits10   = 0;
    static constexpr int  radix          = 0;
    static constexpr int  min_exponent   = 0;
    static constexpr int  min_exponent10 = 0;
    static constexpr int  max_exponent   = 0;
    static constexpr int  max_exponent10 = 0;
    static constexpr bool has_infinity   = false;
    static constexpr bool has_quiet_NaN  = false;
    static constexpr bool traps          = false;

    static constexpr T min() noexcept { return T(); }
    static constexpr T max() noexcept { return T(); }
    static constexpr T lowest() noexcept { return T(); }
    static constexpr T epsilon() noexcept { return T(); }
    static constexpr T round_error() noexcept { return T(); }
    static constexpr T infinity() noexcept { return T(); }
    static constexpr T quiet_NaN() noexcept { return T(); }
    static constexpr T signaling_NaN() noexcept { return T(); }
    static constexpr T denorm_min() noexcept { return T(); }
};

// Helper macro to define an integer specialization.
#define _TATERTOS_NL_INT(T, MIN_, MAX_, IS_SIGNED, DIGITS, DIGITS10) \
    template<> struct numeric_limits<T> {                            \
        static constexpr bool is_specialized = true;                 \
        static constexpr bool is_signed = IS_SIGNED;                 \
        static constexpr bool is_integer = true;                     \
        static constexpr bool is_exact = true;                       \
        static constexpr bool is_iec559 = false;                     \
        static constexpr bool is_bounded = true;                     \
        static constexpr bool is_modulo = !(IS_SIGNED);              \
        static constexpr int  digits = DIGITS;                       \
        static constexpr int  digits10 = DIGITS10;                   \
        static constexpr int  max_digits10 = 0;                      \
        static constexpr int  radix = 2;                             \
        static constexpr int  min_exponent = 0;                      \
        static constexpr int  max_exponent = 0;                      \
        static constexpr bool has_infinity = false;                  \
        static constexpr bool has_quiet_NaN = false;                 \
        static constexpr bool traps = false;                         \
        static constexpr T min() noexcept { return MIN_; }           \
        static constexpr T max() noexcept { return MAX_; }           \
        static constexpr T lowest() noexcept { return MIN_; }        \
        static constexpr T epsilon() noexcept { return 0; }          \
        static constexpr T round_error() noexcept { return 0; }      \
    }

_TATERTOS_NL_INT(bool,               false,           true,           false, 1, 0);
_TATERTOS_NL_INT(char,               CHAR_MIN,        CHAR_MAX,        true, 7, 2);
_TATERTOS_NL_INT(signed char,        SCHAR_MIN,       SCHAR_MAX,       true, 7, 2);
_TATERTOS_NL_INT(unsigned char,      0,               UCHAR_MAX,       false, 8, 2);
_TATERTOS_NL_INT(short,              SHRT_MIN,        SHRT_MAX,        true, 15, 4);
_TATERTOS_NL_INT(unsigned short,     0,               USHRT_MAX,       false, 16, 4);
_TATERTOS_NL_INT(int,                INT_MIN,         INT_MAX,         true, 31, 9);
_TATERTOS_NL_INT(unsigned int,       0,               UINT_MAX,        false, 32, 9);
_TATERTOS_NL_INT(long,               LONG_MIN,        LONG_MAX,        true, 63, 18);
_TATERTOS_NL_INT(unsigned long,      0,               ULONG_MAX,       false, 64, 19);
_TATERTOS_NL_INT(long long,          LLONG_MIN,       LLONG_MAX,       true, 63, 18);
_TATERTOS_NL_INT(unsigned long long, 0,               ULLONG_MAX,      false, 64, 19);

#undef _TATERTOS_NL_INT

// char16_t / char32_t — minimal manual specializations (the macro
// has been #undef'd above so we declare these by hand).
template<> struct numeric_limits<char16_t> {
    static constexpr bool is_specialized = true;
    static constexpr bool is_signed = false;
    static constexpr bool is_integer = true;
    static constexpr bool is_exact = true;
    static constexpr bool is_iec559 = false;
    static constexpr bool is_bounded = true;
    static constexpr bool is_modulo = true;
    static constexpr int  digits = 16;
    static constexpr int  digits10 = 4;
    static constexpr int  max_digits10 = 0;
    static constexpr int  radix = 2;
    static constexpr int  min_exponent = 0;
    static constexpr int  max_exponent = 0;
    static constexpr bool has_infinity = false;
    static constexpr bool has_quiet_NaN = false;
    static constexpr bool traps = false;
    static constexpr char16_t min() noexcept { return 0; }
    static constexpr char16_t max() noexcept { return 0xFFFF; }
    static constexpr char16_t lowest() noexcept { return 0; }
    static constexpr char16_t epsilon() noexcept { return 0; }
    static constexpr char16_t round_error() noexcept { return 0; }
};

template<> struct numeric_limits<char32_t> {
    static constexpr bool is_specialized = true;
    static constexpr bool is_signed = false;
    static constexpr bool is_integer = true;
    static constexpr bool is_exact = true;
    static constexpr bool is_iec559 = false;
    static constexpr bool is_bounded = true;
    static constexpr bool is_modulo = true;
    static constexpr int  digits = 32;
    static constexpr int  digits10 = 9;
    static constexpr int  max_digits10 = 0;
    static constexpr int  radix = 2;
    static constexpr int  min_exponent = 0;
    static constexpr int  max_exponent = 0;
    static constexpr bool has_infinity = false;
    static constexpr bool has_quiet_NaN = false;
    static constexpr bool traps = false;
    static constexpr char32_t min() noexcept { return 0; }
    static constexpr char32_t max() noexcept { return 0xFFFFFFFFu; }
    static constexpr char32_t lowest() noexcept { return 0; }
    static constexpr char32_t epsilon() noexcept { return 0; }
    static constexpr char32_t round_error() noexcept { return 0; }
};

// Helper for IEEE float types.
#define _TATERTOS_NL_FLOAT(T, MIN_, MAX_, EPS_, DIGITS, DIGITS10, MIN_EXP, MAX_EXP, INF_BUILTIN, NAN_BUILTIN) \
    template<> struct numeric_limits<T> {                              \
        static constexpr bool is_specialized = true;                   \
        static constexpr bool is_signed = true;                        \
        static constexpr bool is_integer = false;                      \
        static constexpr bool is_exact = false;                        \
        static constexpr bool is_iec559 = true;                        \
        static constexpr bool is_bounded = true;                       \
        static constexpr bool is_modulo = false;                       \
        static constexpr int  digits = DIGITS;                         \
        static constexpr int  digits10 = DIGITS10;                     \
        static constexpr int  max_digits10 = DIGITS10 + 2;             \
        static constexpr int  radix = 2;                               \
        static constexpr int  min_exponent = MIN_EXP;                  \
        static constexpr int  max_exponent = MAX_EXP;                  \
        static constexpr bool has_infinity = true;                     \
        static constexpr bool has_quiet_NaN = true;                    \
        static constexpr bool traps = false;                           \
        static T min() noexcept { return MIN_; }                       \
        static T max() noexcept { return MAX_; }                       \
        static T lowest() noexcept { return -MAX_; }                   \
        static T epsilon() noexcept { return EPS_; }                   \
        static T round_error() noexcept { return T(0.5); }             \
        static constexpr T infinity() noexcept { return INF_BUILTIN; } \
        static constexpr T quiet_NaN() noexcept { return NAN_BUILTIN; } \
        static constexpr T signaling_NaN() noexcept { return NAN_BUILTIN; } \
        static constexpr T denorm_min() noexcept { return MIN_; }      \
    }

_TATERTOS_NL_FLOAT(float,       FLT_MIN,  FLT_MAX,  FLT_EPSILON,  FLT_MANT_DIG,  FLT_DIG,  FLT_MIN_EXP,  FLT_MAX_EXP,  __builtin_inff(),  __builtin_nanf(""));
_TATERTOS_NL_FLOAT(double,      DBL_MIN,  DBL_MAX,  DBL_EPSILON,  DBL_MANT_DIG,  DBL_DIG,  DBL_MIN_EXP,  DBL_MAX_EXP,  __builtin_inf(),   __builtin_nan(""));

#undef _TATERTOS_NL_FLOAT

// long double — manually specialized; the macro's T parameter
// chokes on the two-token "long double" inside `numeric_limits<T>`
// instantiation.
template<> struct numeric_limits<long double> {
    static constexpr bool is_specialized = true;
    static constexpr bool is_signed = true;
    static constexpr bool is_integer = false;
    static constexpr bool is_exact = false;
    static constexpr bool is_iec559 = true;
    static constexpr bool is_bounded = true;
    static constexpr bool is_modulo = false;
    static constexpr int  digits = LDBL_MANT_DIG;
    static constexpr int  digits10 = LDBL_DIG;
    static constexpr int  max_digits10 = LDBL_DIG + 2;
    static constexpr int  radix = 2;
    static constexpr int  min_exponent = LDBL_MIN_EXP;
    static constexpr int  max_exponent = LDBL_MAX_EXP;
    static constexpr bool has_infinity = true;
    static constexpr bool has_quiet_NaN = true;
    static constexpr bool traps = false;
    static long double min() noexcept { return LDBL_MIN; }
    static long double max() noexcept { return LDBL_MAX; }
    static long double lowest() noexcept { return -LDBL_MAX; }
    static long double epsilon() noexcept { return LDBL_EPSILON; }
    static long double round_error() noexcept { return 0.5L; }
    static long double infinity() noexcept { return __builtin_infl(); }
    static long double quiet_NaN() noexcept { return __builtin_nanl(""); }
    static long double signaling_NaN() noexcept { return __builtin_nanl(""); }
    static long double denorm_min() noexcept { return LDBL_MIN; }
};

} // namespace std
