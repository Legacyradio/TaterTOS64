// std::addressof — bypass operator& overloads.
template<typename T>
constexpr T* addressof(T& r) noexcept {
    return __builtin_addressof(r);
}

template<typename T, typename... Args>
constexpr T* construct_at(T* p, Args&&... args) {
    return ::new (static_cast<void*>(p)) T(static_cast<Args&&>(args)...);
}

template<typename T>
constexpr void destroy_at(T* p) {
    p->~T();
}

template<typename Alloc>
struct allocator_traits {
    using allocator_type    = Alloc;
    using value_type        = typename Alloc::value_type;
    using pointer           = value_type*;
    using const_pointer     = value_type const*;
    using size_type         = size_t;
    using difference_type   = long;

    struct propagate_on_container_copy_assignment { static constexpr bool value = false; };
    struct propagate_on_container_move_assignment { static constexpr bool value = false; };
    struct propagate_on_container_swap { static constexpr bool value = false; };
    struct is_always_equal { static constexpr bool value = true; };

    static pointer allocate(Alloc& a, size_type n) { return a.allocate(n); }
    static void deallocate(Alloc& a, pointer p, size_type n) { a.deallocate(p, n); }
    static size_type max_size(Alloc const&) noexcept { return static_cast<size_type>(-1) / sizeof(value_type); }
    static Alloc select_on_container_copy_construction(Alloc const& a) noexcept { return a; }

    template<typename T, typename... Args>
    static void construct(Alloc&, T* p, Args&&... args) {
        ::new (static_cast<void*>(p)) T(static_cast<Args&&>(args)...);
    }

    template<typename T>
    static void destroy(Alloc&, T* p) { p->~T(); }
};

template<typename T>
struct default_delete {
    constexpr default_delete() noexcept = default;
    void operator()(T* p) const { ::free(p); }
};

// std::unique_ptr — minimal surface for simdjson and Skia.
template<typename T, typename Deleter = default_delete<T>>
class unique_ptr {
public:
    using pointer = T*;
    using element_type = T;
    using deleter_type = Deleter;

    constexpr unique_ptr() noexcept : m_ptr(nullptr) {}
    constexpr unique_ptr(nullptr_t) noexcept : m_ptr(nullptr) {}
    explicit unique_ptr(T* p) noexcept : m_ptr(p) {}

    ~unique_ptr() { delete_ptr(); }

    unique_ptr(unique_ptr const&) = delete;
    unique_ptr& operator=(unique_ptr const&) = delete;

    unique_ptr(unique_ptr&& other) noexcept : m_ptr(other.m_ptr) {
        other.m_ptr = nullptr;
    }

    template<typename U, typename E>
    unique_ptr(unique_ptr<U, E>&& other) noexcept : m_ptr(other.release()) {}

    unique_ptr& operator=(unique_ptr&& other) noexcept {
        if (this != &other) {
            delete_ptr();
            m_ptr = other.m_ptr;
            other.m_ptr = nullptr;
        }
        return *this;
    }

    template<typename U, typename E>
    unique_ptr& operator=(unique_ptr<U, E>&& other) noexcept {
        reset(other.release());
        return *this;
    }

    T* get() const noexcept { return m_ptr; }
    T& operator*() const { return *m_ptr; }
    T* operator->() const noexcept { return m_ptr; }
    explicit operator bool() const noexcept { return m_ptr != nullptr; }

    T* release() noexcept {
        T* p = m_ptr;
        m_ptr = nullptr;
        return p;
    }

    void reset(T* p = nullptr) noexcept {
        delete_ptr();
        m_ptr = p;
    }

private:
    void delete_ptr() {
        if (m_ptr) {
            Deleter()(m_ptr);
        }
    }

    T* m_ptr;
};

template<typename T, typename... Args>
unique_ptr<T> make_unique(Args&&... args) {
    return unique_ptr<T>(new T(forward<Args>(args)...));
}

// std::shared_ptr — minimal shim for Skia.
template<typename T>
class shared_ptr {
public:
    constexpr shared_ptr() noexcept : m_ptr(nullptr) {}
    constexpr shared_ptr(nullptr_t) noexcept : m_ptr(nullptr) {}
    explicit shared_ptr(T* p) : m_ptr(p) {}

    T* get() const noexcept { return m_ptr; }
    T& operator*() const { return *m_ptr; }
    T* operator->() const noexcept { return m_ptr; }
    explicit operator bool() const noexcept { return m_ptr != nullptr; }

    bool operator==(nullptr_t) const noexcept { return m_ptr == nullptr; }
    bool operator!=(nullptr_t) const noexcept { return m_ptr != nullptr; }

private:
    T* m_ptr;
};

template<typename T, typename... Args>
shared_ptr<T> make_shared(Args&&... args) {
    return shared_ptr<T>(new T(forward<Args>(args)...));
}

template<typename InputIt, typename NoThrowForwardIt>
NoThrowForwardIt uninitialized_move(InputIt first, InputIt last, NoThrowForwardIt d_first) {
    for (; first != last; ++first, (void)++d_first) {
        ::new (static_cast<void*>(addressof(*d_first)))
            typename iterator_traits<NoThrowForwardIt>::value_type(move(*first));
    }
    return d_first;
}

// Array specialization.
template<typename T, typename Deleter>
class unique_ptr<T[], Deleter> {
public:
    using pointer = T*;
    using element_type = T;

    constexpr unique_ptr() noexcept : m_ptr(nullptr) {}
    constexpr unique_ptr(nullptr_t) noexcept : m_ptr(nullptr) {}
    explicit unique_ptr(T* p) noexcept : m_ptr(p) {}

    ~unique_ptr() { if (m_ptr) Deleter()(m_ptr); }

    unique_ptr(unique_ptr const&) = delete;
    unique_ptr& operator=(unique_ptr const&) = delete;

    unique_ptr(unique_ptr&& other) noexcept : m_ptr(other.m_ptr) {
        other.m_ptr = nullptr;
    }

    unique_ptr& operator=(unique_ptr&& other) noexcept {
        if (this != &other) {
            if (m_ptr) Deleter()(m_ptr);
            m_ptr = other.m_ptr;
            other.m_ptr = nullptr;
        }
        return *this;
    }

    T* get() const noexcept { return m_ptr; }
    T& operator[](size_t i) const { return m_ptr[i]; }
    explicit operator bool() const noexcept { return m_ptr != nullptr; }

    T* release() noexcept {
        T* p = m_ptr;
        m_ptr = nullptr;
        return p;
    }

    void reset(T* p = nullptr) noexcept {
        if (m_ptr) Deleter()(m_ptr);
        m_ptr = p;
    }

private:
    T* m_ptr;
};

