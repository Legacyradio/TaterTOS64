// TaterTOS64v3 — minimal <new> for freestanding C++.
// Origin log: logs/fry831.txt
// Surface: enough for placement new + std::nothrow_t + std::nothrow.

#pragma once

#ifndef _GLIBCXX_NEW
#define _GLIBCXX_NEW
#endif

#include <stddef.h>
#include <exception>

namespace std {

struct bad_alloc : public exception {
    virtual char const* what() const noexcept override { return "std::bad_alloc"; }
};

template<typename T>
[[nodiscard]] constexpr T* launder(T* p) noexcept {
    return __builtin_launder(p);
}

struct nothrow_t {
    explicit nothrow_t() = default;
};

extern nothrow_t const nothrow;

// align_val_t — C++17 aligned new/delete tagging type.
enum class align_val_t : size_t {};

} // namespace std

// Placement new — definition required by the standard. The compiler
// recognizes these signatures and emits direct stores instead of any
// allocator call.
inline void* operator new(size_t, void* p) noexcept   { return p; }
inline void* operator new[](size_t, void* p) noexcept { return p; }
inline void  operator delete(void*, void*) noexcept   {}
inline void  operator delete[](void*, void*) noexcept {}

// Throwing-allocation operator new declarations (definitions live in
// AK/kmalloc.cpp via the AK_OS_TATERTOS S1b path → libc malloc).
void* operator new(size_t)   noexcept(false);
void* operator new[](size_t) noexcept(false);
void* operator new(size_t, std::nothrow_t const&) noexcept;
void* operator new[](size_t, std::nothrow_t const&) noexcept;

void operator delete(void*) noexcept;
void operator delete[](void*) noexcept;
void operator delete(void*, size_t) noexcept;
void operator delete[](void*, size_t) noexcept;
void operator delete(void*, std::nothrow_t const&) noexcept;
void operator delete[](void*, std::nothrow_t const&) noexcept;
