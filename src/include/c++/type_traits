namespace _detail {
    template<typename T>
    struct decay_impl {
        using U = typename remove_reference<T>::type;
        using type = conditional_t<
            is_array<U>::value,
            typename remove_extent<U>::type*,
            conditional_t<
                is_function<U>::value,
                typename add_pointer<U>::type,
                remove_cv_t<U>
            >
        >;
    };
}
